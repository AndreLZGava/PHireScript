// This is a comment
myQueue = Queue<String>

myQueue.enqueue('string 1', 'string 2')
    .enqueue('true')
    .enqueue(
      'teste 4',
      'qua',
      'qua'
    )
myQueue.dequeue()
anotherVariableString = 'true'
myQueue.enqueue(anotherVariableString)
