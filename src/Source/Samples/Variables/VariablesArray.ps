/**
*  This are the examples of array cases
*/
//scopedArray = Array<Int|String: String>
//scopedArray = []
//scopedArray[] = 'test'


// Literal inline array (only supported inline for now)
myTest = 'guess'
anotherOne = 'another One'
variables = [
  true,
  'another',
  'test': ['array'],
  0: 'another test',
  myTest: anotherOne,
]

// Array cast
variables2 = Array('test')

variables.contains('another')

variables.add('teste', 'MDS')
.add('omg', ['test': 0])
.destroy('teste')

variables3 = ['test': ['mds']]
variables3.display()

variable4 = [
  0: [
    '#drupal': [
      '#shora': 'neee'
    ]
  ],
  1: [
    '#elements': [
      '#ttttt': 'Shoke de monstro'
    ]
  ]
]

// Variable reference
variablesReference = variables

