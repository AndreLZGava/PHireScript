data = ["apple", "banana"] // Global: ARRAY

resetData() {
    data = "cleared"       // Local: STRING (Shadowing)
    data.toUpperCase()    // must become strtoupper($data)
}

data.add("orange")            // must become array_push($data, "orange")
resetData()
echo data.join(" - ")          // must become \implode(" - ", $data)
